# Copy to .env (gitignored) and fill in. NEVER commit real keys.
#   cp .env.example .env
#
# IMPORTANT: do NOT put inline "# comments" after a value on the same line —
# some .env parsers treat them as part of the value. Keep comments on their own line.
#
# ONE Tavus key covers STT, TTS, a hosted LLM, and the Knowledge Base (RAG),
# plus hackathon credits. In most cases TAVUS_API_KEY is all you need.

# --- Tavus (conversation + STT + LLM + Knowledge Base) ---
# https://platform.tavus.io -> API Keys (ask a Tavus team member for credits).
TAVUS_API_KEY=

# Examiner persona id (you have: pece42dab07f) and its avatar/face id.
TAVUS_PAL_ID=pece42dab07f
TAVUS_FACE_ID=

# In-call STT engine: tavus-soniox keeps fillers; tavus-parakeet = low-latency English.
TAVUS_STT_ENGINE=tavus-soniox

# --- Knowledge Base / RAG (built into Tavus — no vector DB) ---
# Tag names for the band descriptors + question bank uploaded as Tavus documents.
TAVUS_DOCUMENT_TAGS=ielts-rubric,ielts-questions

# --- Webhook (for the post-call assessment loop) ---
# Public URL Tavus calls with recording_ready / tool_call events. Locally, use a
# tunnel (e.g. ngrok http 8000) and paste its https URL here. Leave blank to skip.
TAVUS_CALLBACK_URL=

# --- Grading: no separate LLM key needed ---
# The Tavus PAL grades by calling the submit_ielts_assessment tool; we feed Charsiu/
# feature measurements in as context so Pronunciation is grounded.

# --- Pronunciation + word-timing backbone (local, MIT, no key) ---
CHARSIU_MODEL=charsiu/en_w2v2_fc_10ms

# --- Demo server ---
PORT=8000
